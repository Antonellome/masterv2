rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Regola di base: Permetti la lettura e la scrittura solo agli utenti autenticati.
    // Questo è un buon punto di partenza per la maggior parte delle applicazioni.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}