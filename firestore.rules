rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regola specifica per lo storico delle notifiche
    // Permette a chiunque (incluse le Cloud Functions) di scrivere qui.
    match /notificheInviate/{docId} {
      allow write: if true;
    }

    // Regola generale per tutto il resto del database
    // Richiede che l'utente sia autenticato
    match /{path=**} {
      allow read, write: if request.auth != null;
    }
  }
}