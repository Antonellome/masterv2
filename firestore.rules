rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGOLA #1: Un utente con il ruolo 'admin' ha accesso completo a tutti i dati.
    // Questa regola è la chiave per sbloccare l'intera applicazione.
    match /{document=**} {
      allow read, write: if request.auth.token.role == 'admin';
    }

    // Per ora, nessun'altra regola viene definita per evitare conflitti.
    // Questo garantisce che la regola per l'admin non venga sovrascritta.
    // Una volta che l'app funziona, potremo aggiungere in sicurezza regole 
    // per altri ruoli, se necessario.
  }
}
